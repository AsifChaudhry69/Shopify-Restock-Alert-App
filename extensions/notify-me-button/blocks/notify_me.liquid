{% if product.available == false %}

{% assign app_url = section.settings.app_url %}

<div id="notify-me-wrapper" style="margin: 16px 0;">

  <!-- Bell Icon Button -->
  <div id="notify-bell-btn" onclick="openNotifyPopup()" style="
    background: {{ section.settings.bell_bg_color }};
    width: {{ section.settings.bell_size }}px;
    height: {{ section.settings.bell_size }}px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    font-size: {{ section.settings.bell_icon_size }}px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.2);
  ">
    {{ section.settings.bell_icon }}
  </div>

  <!-- Overlay -->
  <div id="notify-overlay" onclick="closeNotifyPopup()" style="
    display: none;
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    background: rgba(0,0,0,0.5);
    z-index: 9998;
  "></div>

  <!-- Popup -->
  <div id="notify-popup" style="
    display: none;
    position: fixed;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    background: {{ section.settings.popup_bg_color }};
    border-radius: {{ section.settings.popup_border_radius }}px;
    padding: 32px;
    width: 90%;
    max-width: 400px;
    z-index: 9999;
    box-shadow: 0 20px 60px rgba(0,0,0,0.3);
    font-family: {{ section.settings.font_family }};
  ">
    <!-- Close X -->
    <button onclick="closeNotifyPopup()" style="
      position: absolute;
      top: 12px; right: 16px;
      background: none;
      border: none;
      font-size: 20px;
      cursor: pointer;
      color: #888;
    ">✕</button>

    <!-- Header -->
    <div style="text-align: center; margin-bottom: 20px;">
      <div style="font-size: 40px; margin-bottom: 8px;">{{ section.settings.bell_icon }}</div>
      <h3 style="
        margin: 0;
        font-size: {{ section.settings.title_size }}px;
        color: {{ section.settings.title_color }};
        font-weight: {{ section.settings.title_weight }};
        font-family: {{ section.settings.font_family }};
      ">{{ section.settings.popup_title }}</h3>
      <p style="
        margin: 8px 0 0;
        font-size: {{ section.settings.subtitle_size }}px;
        color: {{ section.settings.subtitle_color }};
      ">
        {{ section.settings.popup_subtitle }} <strong>{{ product.title }}</strong>
      </p>
    </div>

    <!-- Email Input -->
    <input
      type="email"
      id="notify-email"
      placeholder="{{ section.settings.input_placeholder }}"
      style="
        width: 100%;
        padding: 12px 16px;
        border: 2px solid {{ section.settings.input_border_color }};
        border-radius: {{ section.settings.input_border_radius }}px;
        font-size: {{ section.settings.input_font_size }}px;
        outline: none;
        box-sizing: border-box;
        margin-bottom: 12px;
        background: {{ section.settings.input_bg_color }};
        color: {{ section.settings.input_text_color }};
        font-family: {{ section.settings.font_family }};
      "
      onkeypress="if(event.key==='Enter') saveNotify()"
    />

    <!-- Error Message -->
    <div id="notify-error" style="
      display: none;
      color: red;
      font-size: 12px;
      margin-bottom: 8px;
    ">{{ section.settings.error_text }}</div>

    <!-- Buttons Row -->
    <div style="display: flex; gap: 10px;">
      <button onclick="closeNotifyPopup()" style="
        flex: 1;
        padding: 12px;
        border: 2px solid {{ section.settings.cancel_border_color }};
        border-radius: {{ section.settings.btn_border_radius }}px;
        background: {{ section.settings.cancel_bg_color }};
        color: {{ section.settings.cancel_text_color }};
        font-size: {{ section.settings.btn_font_size }}px;
        cursor: pointer;
        font-weight: 600;
        font-family: {{ section.settings.font_family }};
      ">{{ section.settings.cancel_btn_text }}</button>

      <button id="notify-save-btn" onclick="saveNotify()" style="
        flex: 1;
        padding: 12px;
        border: none;
        border-radius: {{ section.settings.btn_border_radius }}px;
        background: {{ section.settings.save_btn_bg_color }};
        color: {{ section.settings.save_btn_text_color }};
        font-size: {{ section.settings.btn_font_size }}px;
        cursor: pointer;
        font-weight: 600;
        font-family: {{ section.settings.font_family }};
      ">{{ section.settings.save_btn_text }}</button>
    </div>
  </div>

  <!-- Success Popup -->
  <div id="notify-success-popup" style="
    display: none;
    position: fixed;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    background: {{ section.settings.popup_bg_color }};
    border-radius: {{ section.settings.popup_border_radius }}px;
    padding: 32px;
    width: 90%;
    max-width: 400px;
    z-index: 9999;
    box-shadow: 0 20px 60px rgba(0,0,0,0.3);
    font-family: {{ section.settings.font_family }};
    text-align: center;
  ">
    <div style="font-size: 48px; margin-bottom: 12px;">✅</div>
    <h3 style="
      margin: 0 0 8px;
      color: {{ section.settings.title_color }};
      font-size: {{ section.settings.title_size }}px;
      font-weight: {{ section.settings.title_weight }};
    ">{{ section.settings.success_title }}</h3>
    <p style="
      color: {{ section.settings.subtitle_color }};
      font-size: {{ section.settings.subtitle_size }}px;
    ">
      {{ section.settings.success_message }} <strong id="confirmed-email"></strong>
    </p>
    <button onclick="closeSuccessPopup()" style="
      margin-top: 20px;
      padding: 12px 32px;
      background: {{ section.settings.save_btn_bg_color }};
      color: {{ section.settings.save_btn_text_color }};
      border: none;
      border-radius: {{ section.settings.btn_border_radius }}px;
      font-size: {{ section.settings.btn_font_size }}px;
      cursor: pointer;
      font-weight: 600;
      font-family: {{ section.settings.font_family }};
    ">{{ section.settings.done_btn_text }}</button>
  </div>

</div>

<script>
function openNotifyPopup() {
  document.getElementById('notify-overlay').style.display = 'block';
  document.getElementById('notify-popup').style.display = 'block';
  document.getElementById('notify-email').focus();
}

function closeNotifyPopup() {
  document.getElementById('notify-overlay').style.display = 'none';
  document.getElementById('notify-popup').style.display = 'none';
  document.getElementById('notify-error').style.display = 'none';
  document.getElementById('notify-email').value = '';
}

function closeSuccessPopup() {
  document.getElementById('notify-overlay').style.display = 'none';
  document.getElementById('notify-success-popup').style.display = 'none';
}

async function saveNotify() {
  var email = document.getElementById('notify-email').value.trim();
  var appUrl = {{ section.settings.app_url | json }};

  if (!email || email.indexOf('@') === -1) {
    alert('Please enter a valid email address');
    return;
  }

  var btn = document.getElementById('notify-save-btn');
  btn.textContent = 'Saving...';
  btn.disabled = true;

  try {
    var response = await fetch(appUrl + '/api/subscribe', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        email: email,
        productId: '{{ product.id }}',
        variantId: '{{ product.selected_or_first_available_variant.id }}',
        shop: '{{ shop.permanent_domain }}',
        productTitle: '{{ product.title }}',
        productUrl: '{{ shop.url }}/products/{{ product.handle }}',
        storeName: '{{ shop.name }}'
      })
    });

    if (response.ok) {
      document.getElementById('notify-popup').style.display = 'none';
      document.getElementById('confirmed-email').textContent = email;
      document.getElementById('notify-success-popup').style.display = 'block';
      document.getElementById('notify-bell-btn').style.background = '{{ section.settings.success_bell_color }}';
    } else {
      document.getElementById('notify-error').style.display = 'block';
      btn.textContent = {{ section.settings.save_btn_text | json }};
      btn.disabled = false;
    }
  } catch (err) {
    document.getElementById('notify-error').style.display = 'block';
    btn.textContent = {{ section.settings.save_btn_text | json }};
    btn.disabled = false;
  }
}
</script>

{% endif %}

{% schema %}
